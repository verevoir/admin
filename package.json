{
  "name": "@verevoir/admin",
  "version": "0.4.0",
  "license": "MIT",
  "description": "Composable building blocks for a Verevoir-powered admin site — shell, editor, list, with first-class slots for versioning, preview, and user management.",
  "homepage": "https://verevoir.io",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./astro": {
      "types": "./dist/astro/index.d.ts",
      "import": "./dist/astro/index.js",
      "require": "./dist/astro/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./styles/*": "./dist/styles/*"
  },
  "files": [
    "dist",
    "dist/styles"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:verevoir/admin.git"
  },
  "funding": "https://buymeacoffee.com/verevoir",
  "scripts": {
    "prepare": "npm run build",
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@verevoir/editor": "file:../editor",
    "@verevoir/schema": "file:../schema-engine",
    "@verevoir/storage": "^1.1.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "7.1.0-canary-705268dc-20260409",
    "prettier": "^3.8.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  }
}
